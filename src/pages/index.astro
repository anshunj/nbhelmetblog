---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProducts = await getCollection('products', ({ data }) => !data.draft);
const products = allProducts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Riderment 安全帽選購誌"
  description="從通勤到長途旅行，實測、比較、選購建議——一個專注於安全帽商品介紹的極簡部落格。"
>
  <section class="hero">
    <h1>戴對帽子，才談得上騎得安心。</h1>
    <p class="hero-sub">這裡記錄每一款帽子實際戴上去的感覺，不是規格表的複製貼上。</p>
  </section>

  <ul class="post-list">
    {
      products.map((product) => {
        return (
          <li class="post-item">
            <a href={`/products/${product.id}/`} class="post-link">
              <img
                src={product.data.image}
                alt={product.data.image_alt}
                width="120"
                height="120"
                loading="lazy"
                class="post-thumb"
              />
              <div class="post-body">
                <span class="post-category">{product.data.category}</span>
                <h2>{product.data.title}</h2>
                <p>{product.data.description}</p>
                <time datetime={product.data.publishDate.toISOString()}>
                  {product.data.publishDate.toLocaleDateString('zh-TW', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</BaseLayout>

<style>
  .hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-hairline);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.6rem, 4vw, 2.3rem);
    line-height: 1.3;
    margin: 0 0 0.75rem;
    max-width: 16ch;
  }

  .hero-sub {
    color: var(--color-asphalt);
    margin: 0;
    font-size: 1rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-hairline);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-hairline);
  }

  .post-link {
    display: flex;
    gap: 1.25rem;
    padding: 1.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-thumb {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    object-fit: cover;
    background: var(--color-hairline);
  }

  .post-body {
    min-width: 0;
  }

  .post-category {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--color-signal);
    text-transform: uppercase;
  }

  .post-body h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    margin: 0.25rem 0 0.4rem;
  }

  .post-body p {
    margin: 0 0 0.5rem;
    color: var(--color-asphalt);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-body time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-asphalt);
    opacity: 0.7;
  }

  @media (max-width: 540px) {
    .post-thumb {
      width: 84px;
      height: 84px;
    }
  }
</style>
